datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String    @id @default(cuid())
  email    String    @unique
  password String

  sessions Session[]
  orders   Order[]   // 🔥 relação adicionada
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  status      String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[] // 🔥 relação com pedidos
}

model Order {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])

  total     Float
  status    String       @default("pending") // 🔥 importante pra fluxo real

  items     OrderItem[]

  createdAt DateTime     @default(now())
}

model OrderItem {
  id        String   @id @default(cuid())

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  quantity  Int
}